{
  "name": "intolibya-static-blog",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "generate:og": "tsx scripts/generate-og-images.ts",
    "lint:posts": "python3 scripts/lint-post-guest-prose.py",
    "prebuild": "npm run lint:posts && npm run generate:og",
    "build": "astro build",
    "preview": "astro preview",
    "import:wp": "tsx scripts/import-wordpress-to-md.ts",
    "import:status": "tsx scripts/import-wordpress-to-md.ts --status",
    "validate:urls": "tsx scripts/validate-url-parity.ts",
    "writer": "node tools/blog-writer/serve.mjs",
    "media:index": "tsx scripts/index-media.ts",
    "media:backfill-derivatives": "tsx scripts/backfill-media-derivatives.ts",
    "media:consolidate": "tsx scripts/consolidate-media-duplicates.ts",
    "translate:missing": "tsx scripts/translate-missing.ts",
    "migrate:destinations": "tsx scripts/migrate-places-to-destinations.ts",
    "sync:destination-redirects": "tsx scripts/sync-destination-short-redirects.ts",
    "test:analytics": "tsx scripts/test-analytics.ts"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^11.0.2",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.7",
    "rehype-raw": "^7.0.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.5",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^5.2.1",
    "tsx": "^4.23.0",
    "vite": "^7.3.6",
    "zod": "^4.4.3"
  }
}
