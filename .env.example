# WordPress site (crawl / import)
WP_URL=https://intolibya.com
WP_USER=your-wp-username
WP_APP_PASSWORD=your-application-password

# Import throttling (slow extraction)
IMPORT_BATCH_SIZE=3
IMPORT_DELAY_MS=3000
IMPORT_PAGE_DELAY_MS=5000

# Blog writer — automatic translations (local dev only)
OPENAI_API_KEY=your-openai-api-key
# Optional override:
# OPENAI_MODEL=gpt-4o-mini

# Google Analytics 4 (leave blank to disable)
# Find this in GA → Admin → Data streams → Web → Measurement ID (format: G-XXXXXXXXXX)
PUBLIC_GA_MEASUREMENT_ID=G-H6N6QW4W7T
