# WordPress site (crawl / import)
WP_URL=https://intolibya.com
WP_USER=your-wp-username
WP_APP_PASSWORD=your-application-password

# Import throttling (slow extraction)
IMPORT_BATCH_SIZE=3
IMPORT_DELAY_MS=3000
IMPORT_PAGE_DELAY_MS=5000

# Blog writer / batch translations (local Ollama by default — run batches on the Mac Mini)
TRANSLATE_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5:14b
# Optional paid fallback instead of Ollama:
# TRANSLATE_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# Google Analytics 4 (shared stream with TourBuilder web — leave blank to disable)
# Measurement ID: G-H6N6QW4W7T — see docs/ANALYTICS.md
PUBLIC_GA_MEASUREMENT_ID=G-H6N6QW4W7T

# Scheduled publishing (GitHub Actions secret — not used locally)
# Create in Vercel → Project → Settings → Git → Deploy Hooks, then add the URL as
# repo secret VERCEL_DEPLOY_HOOK_URL for .github/workflows/publish-schedule.yml
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
