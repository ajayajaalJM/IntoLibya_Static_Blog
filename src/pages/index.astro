---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCTA from '../components/HeroCTA.astro';
import TourPackagesGrid from '../components/TourPackagesGrid.astro';
import ActivityGrid from '../components/ActivityGrid.astro';
import EventsGrid from '../components/EventsGrid.astro';
import BlogPreview from '../components/BlogPreview.astro';
import Testimonial from '../components/Testimonial.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { getSiteConfig } from '../lib/site';

const site = getSiteConfig();
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://intolibya.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'IntoLibya',
      url: siteUrl,
      logo: `${siteUrl}${site.logo}`,
    },
    {
      '@type': 'WebSite',
      name: 'IntoLibya',
      url: siteUrl,
      potentialAction: {
        '@type': 'SearchAction',
        target: `${siteUrl}/tourbuilder/search/?q={search_term_string}`,
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};
---

<BaseLayout
  title="Visit Libya — IntoLibya Tours & Travel Guides"
  description={site.heroSubheadline}
  canonical={`${siteUrl}/`}
  jsonLd={jsonLd}
>
  <HeroCTA />

  <section class="px-4 py-12 md:px-8 md:py-16">
    <div class="mx-auto max-w-6xl">
      <p class="text-sm font-bold uppercase tracking-widest text-brass">How it works</p>
      <h2 class="mt-2 text-2xl font-black uppercase tracking-wide text-charcoal md:text-3xl">
        Build your trip in 3 steps
      </h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 md:grid-cols-3 md:gap-6">
        {[
          { step: '1', title: 'Pick a tour or activities', body: 'Start from a package, event, or hand-pick experiences across Libya.', accent: 'border-mint' },
          { step: '2', title: 'Build your itinerary', body: 'Add activities day by day in TourBuilder booking.', accent: 'border-brass' },
          { step: '3', title: 'Submit for a quote', body: 'Send your plan to IntoLibya and get a tailored proposal.', accent: 'border-sand' },
        ].map((item) => (
          <div class={`card border-l-8 ${item.accent} p-5 sm:p-6`}>
            <span class="text-3xl font-black text-brass">{item.step}</span>
            <h3 class="mt-3 text-lg font-bold text-charcoal">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <TourPackagesGrid />
  <EventsGrid />
  <ActivityGrid />
  <Testimonial />
  <BlogPreview />
  <FinalCTA />
</BaseLayout>
