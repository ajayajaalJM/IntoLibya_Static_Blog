---
import BaseLayout from '../layouts/BaseLayout.astro';
import FinalCTA from '../components/FinalCTA.astro';
import RelatedReading from '../components/RelatedReading.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import ImageGallery from '../components/ImageGallery.astro';
import BodyWithGalleries from '../components/BodyWithGalleries.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TripResourceLinks from '../components/TripResourceLinks.astro';
import { getAllPosts, getAllPostsIncludingDrafts, getTranslationSiblings } from '../lib/posts';
import { getAllDestinationsIncludingDrafts } from '../lib/destinations';
import { galleriesAt, galleryImageObjects } from '../lib/galleries';
import { LANG_LABELS, type Lang } from '../lib/post-schema';
import { ogPathForFeaturedImage } from '../lib/og';
import { extractRelatedReading, resolveRelatedCards } from '../lib/related-reading';
import { buildImageObject, readMediaCatalogDimensions } from '../lib/image-sitemap';
import { blogPostCrumbs, buildBreadcrumbListJsonLd } from '../lib/seo-links';
import { fileURLToPath } from 'node:url';
import path from 'node:path';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => {
    const segments = post.data.canonicalPath.replace(/^\/|\/$/g, '').split('/');
    return {
      params: { path: segments.join('/') },
      props: { post, id: post.id },
    };
  });
}

const { post } = Astro.props;
const galleries = post.data.galleries ?? [];
const afterHero = galleriesAt(galleries, 'after-hero');
const afterBody = galleriesAt(galleries, 'after-body');

const { bodyHtml, links: relatedLinks } = extractRelatedReading(post.body);
const [allPostsForRelated, allDestsForRelated] = await Promise.all([
  getAllPostsIncludingDrafts(),
  getAllDestinationsIncludingDrafts(),
]);
const relatedCards = resolveRelatedCards(
  relatedLinks,
  allPostsForRelated,
  allDestsForRelated,
  post.data.lang,
);

const allPosts = await getAllPosts();
const siblings = getTranslationSiblings(post, allPosts);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://intolibya.com';
const lang = post.data.lang as Lang;
const ogImage = ogPathForFeaturedImage(post.data.featuredImage);

const hreflangAlternates = [
  { lang, href: `${siteUrl}${post.data.canonicalPath}` },
  ...siblings.map((s) => ({
    lang: s.data.lang,
    href: `${siteUrl}${s.data.canonicalPath}`,
  })),
  { lang: 'x-default', href: `${siteUrl}${post.data.canonicalPath}` },
];

const repoRoot = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '../..');
const mediaMeta = await readMediaCatalogDimensions(repoRoot);
const imageObjects = galleryImageObjects(galleries, siteUrl, mediaMeta);
const heroMeta = mediaMeta.get(post.data.featuredImage);
const heroObject = buildImageObject(siteUrl, {
  src: post.data.featuredImage,
  alt: post.data.featuredImageAlt?.trim() || heroMeta?.defaultAlt || post.data.title,
  name: post.data.title,
  width: heroMeta?.width,
  height: heroMeta?.height,
  credit: heroMeta?.credit,
});
if (heroObject) imageObjects.unshift(heroObject);

const blogLabel = `${LANG_LABELS[lang]} Blog`;
const breadcrumbItems = blogPostCrumbs(lang, blogLabel, post.data.title, post.data.canonicalPath);

const jsonLd: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.data.seo.title,
    description: post.data.seo.description,
    datePublished: post.data.publishedAt.toISOString(),
    mainEntityOfPage: post.data.seo.canonical,
    primaryImageOfPage: heroObject || undefined,
    image: [
      `${siteUrl}${ogImage}`,
      ...imageObjects.map((img) => img.contentUrl as string),
    ],
    author: { '@type': 'Organization', name: 'IntoLibya', url: siteUrl },
    publisher: { '@type': 'Organization', name: 'IntoLibya', url: siteUrl },
    inLanguage: lang,
  },
  buildBreadcrumbListJsonLd(breadcrumbItems, siteUrl),
  ...imageObjects.map((img) => ({
    '@context': 'https://schema.org',
    ...img,
  })),
];
---

<BaseLayout
  title={post.data.seo.title}
  description={post.data.seo.description}
  canonical={post.data.seo.canonical}
  ogImage={ogImage}
  ogType="article"
  articlePublishedTime={post.data.publishedAt.toISOString()}
  articleAuthor="IntoLibya"
  articleSection={`${LANG_LABELS[lang]} Travel Blog`}
  lang={lang}
  hreflangAlternates={hreflangAlternates}
  jsonLd={jsonLd}
>
  <article class="px-4 py-10 md:px-8">
    <div class="mx-auto max-w-[42rem]">
      <Breadcrumbs items={breadcrumbItems} />

      <OptimizedImage
        src={post.data.featuredImage}
        alt={post.data.featuredImageAlt?.trim() || post.data.title}
        width={1200}
        height={675}
        widths={[640, 960, 1200]}
        sizes="(max-width: 768px) 100vw, 672px"
        pictureClass="hero-arch mb-10 block overflow-hidden"
        class="h-64 w-full object-cover md:h-96"
        loading="eager"
        fetchpriority="high"
        quality={70}
      />

      <header class="mb-10">
        <time
          class="text-xs font-medium tracking-[0.08em] text-muted uppercase"
          datetime={post.data.publishedAt.toISOString()}
        >
          {post.data.publishedAt.toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="mt-4 font-serif text-[1.85rem] font-semibold leading-snug text-balance text-charcoal md:text-[2.15rem]">
          {post.data.title}
        </h1>
      </header>

      {siblings.length > 0 && (
        <div class="mb-10 flex flex-wrap gap-x-3 gap-y-2">
          {[{ lang, path: post.data.canonicalPath, current: true }, ...siblings.map((s) => ({ lang: s.data.lang, path: s.data.canonicalPath, current: false }))].map((t) => (
            <a
              href={t.path}
              class:list={[
                'text-xs font-medium tracking-wide transition',
                t.current
                  ? 'text-charcoal underline decoration-mint decoration-2 underline-offset-4'
                  : 'text-muted hover:text-brass',
              ]}
              hreflang={t.lang}
            >
              {LANG_LABELS[t.lang as Lang]}
            </a>
          ))}
        </div>
      )}

      {afterHero.map((gallery) => <ImageGallery gallery={gallery} />)}

      <div class="prose-blog">
        <BodyWithGalleries body={bodyHtml} galleries={galleries} />
      </div>

      {afterBody.map((gallery) => <ImageGallery gallery={gallery} />)}
    </div>
  </article>
  <RelatedReading items={relatedCards} />
  <TripResourceLinks variant="compact" markEnglishHubs={lang !== 'en'} />
  <FinalCTA />
</BaseLayout>
