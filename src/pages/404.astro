---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteConfig } from '../lib/site';

const site = getSiteConfig();
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://intolibya.com';

const destinations = [
  {
    href: '/',
    label: 'Home',
    description: 'Back to the main oasis',
    icon: 'home',
    accent: 'from-brass/20 to-brass/5',
  },
  {
    href: site.primaryCtaUrl,
    label: 'TourBuilder',
    description: 'Design your Libya adventure',
    icon: 'compass',
    accent: 'from-mint/25 to-mint/5',
    featured: true,
  },
  {
    href: '/#events',
    label: 'Events',
    description: 'Festivals, tours & happenings',
    icon: 'calendar',
    accent: 'from-brass/15 to-sand',
  },
  {
    href: '/#activities',
    label: 'Activities',
    description: 'Walking tours, markets & more',
    icon: 'activity',
    accent: 'from-sand to-whitewash',
  },
];

const lostMessages = [
  'Looks like this oasis dried up.',
  'You’ve wandered off the caravan route.',
  'Even the Sahara couldn’t find this page.',
  'Wrong turn in the medina?',
  'This Roman ruin seems to have crumbled away.',
  'The dunes shifted — this URL is gone.',
];
---

<BaseLayout
  title="Page not found — IntoLibya"
  description="This page got lost in the Sahara. Head back home or build your Libya trip with TourBuilder."
  canonical={`${siteUrl}/404`}
  ogImage={site.ogImage}
  pinterestImage={site.pinterestImage}
>
  <section class="not-found relative min-h-[calc(100vh-8rem)] overflow-hidden px-4 py-10 md:px-8 md:py-14">
    <div class="not-found-bg" aria-hidden="true">
      <div class="not-found-dune not-found-dune-1"></div>
      <div class="not-found-dune not-found-dune-2"></div>
      <div class="not-found-dune not-found-dune-3"></div>
      <div class="not-found-stars"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-4xl text-center">
      <div class="not-found-compass mx-auto mb-6" aria-hidden="true">
        <svg viewBox="0 0 96 96" fill="none" class="h-20 w-20 md:h-24 md:w-24">
          <circle cx="48" cy="48" r="44" stroke="currentColor" stroke-width="2" class="text-brass/40" />
          <circle cx="48" cy="48" r="34" stroke="currentColor" stroke-width="1.5" class="text-brass/25" />
          <g class="not-found-needle">
            <path d="M48 18 L52 48 L48 44 L44 48 Z" fill="#c29f5d" />
            <path d="M48 78 L44 48 L48 52 L52 48 Z" fill="#837a71" opacity="0.85" />
          </g>
          <circle cx="48" cy="48" r="4" fill="#c29f5d" />
        </svg>
      </div>

      <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-brass">Lost in Libya</p>

      <h1 class="not-found-code mt-3 font-black tracking-tight text-charcoal">
        <span class="not-found-digit">4</span>
        <span class="not-found-digit not-found-digit-mid">0</span>
        <span class="not-found-digit">4</span>
      </h1>

      <p class="mt-4 text-lg font-bold text-charcoal md:text-xl">This page isn’t on the map</p>

      <p id="not-found-message" class="mt-2 min-h-[1.75rem] text-base text-muted transition-opacity duration-500 md:text-lg">
        {lostMessages[0]}
      </p>

      <div class="not-found-grid mt-10 grid gap-3 sm:grid-cols-2 md:grid-cols-3">
        {destinations.map((dest, index) => (
          <a
            href={dest.href}
            class:list={[
              'not-found-card group relative flex items-center gap-4 overflow-hidden rounded-2xl border border-border/80 bg-white/90 p-4 text-left shadow-[0_12px_32px_rgba(45,42,38,0.06)] backdrop-blur-sm transition hover:-translate-y-1 hover:border-brass/40 hover:shadow-[0_18px_40px_rgba(194,159,93,0.18)] md:p-5',
              dest.featured && 'featured sm:col-span-2 sm:gap-5 sm:p-6 md:col-span-3 md:order-first',
            ]}
            style={`animation-delay: ${index * 90}ms`}
          >
            <div class:list={['absolute inset-0 bg-gradient-to-br opacity-70', dest.accent]} aria-hidden="true"></div>

            <span
              class:list={[
                'not-found-card-icon relative flex shrink-0 items-center justify-center rounded-2xl border border-brass/20 bg-gradient-to-br from-white to-sand/80 text-brass shadow-[inset_0_1px_0_rgba(255,255,255,0.9)]',
                dest.featured ? 'h-14 w-14' : 'h-12 w-12',
              ]}
              aria-hidden="true"
            >
              {dest.icon === 'home' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="not-found-icon-svg">
                  <path d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                </svg>
              )}
              {dest.icon === 'compass' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="not-found-icon-svg">
                  <path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              )}
              {dest.icon === 'calendar' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="not-found-icon-svg">
                  <path d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                </svg>
              )}
              {dest.icon === 'activity' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="not-found-icon-svg">
                  <path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
                </svg>
              )}
            </span>

            <span class="relative min-w-0 flex-1">
              <span class="flex flex-wrap items-center gap-2 text-base font-extrabold text-charcoal group-hover:text-brass">
                {dest.label}
                {dest.featured && (
                  <span class="rounded-full bg-brass px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white">
                    Start here
                  </span>
                )}
              </span>
              <span class="mt-0.5 block text-sm leading-snug text-muted">{dest.description}</span>
            </span>

            <span class="not-found-card-arrow relative flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-brass/15 bg-white/70 text-brass" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                <path d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>

      <p class="mt-8 text-sm text-muted">
        Need a hand?
        <a href={`mailto:${site.contact.email}`} class="font-semibold text-brass underline-offset-2 hover:underline">
          {site.contact.email}
        </a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgb(194 159 93 / 0.18), transparent 55%),
      linear-gradient(180deg, var(--color-whitewash) 0%, var(--color-sand) 55%, #e8dcc8 100%);
  }

  .not-found-dune {
    position: absolute;
    bottom: -5%;
    left: -10%;
    width: 120%;
    height: 38%;
    border-radius: 50% 50% 0 0;
    background: linear-gradient(180deg, rgb(194 159 93 / 0.12) 0%, rgb(194 159 93 / 0.04) 100%);
    animation: duneDrift 14s ease-in-out infinite alternate;
  }

  .not-found-dune-2 {
    bottom: -12%;
    height: 32%;
    opacity: 0.7;
    animation-duration: 18s;
    animation-direction: alternate-reverse;
  }

  .not-found-dune-3 {
    bottom: -18%;
    height: 26%;
    opacity: 0.45;
    animation-duration: 22s;
  }

  .not-found-stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 15% 18%, rgb(194 159 93 / 0.35) 0 1px, transparent 2px),
      radial-gradient(circle at 72% 24%, rgb(194 159 93 / 0.25) 0 1px, transparent 2px),
      radial-gradient(circle at 38% 12%, rgb(194 159 93 / 0.2) 0 1px, transparent 2px),
      radial-gradient(circle at 88% 32%, rgb(194 159 93 / 0.18) 0 1px, transparent 2px);
    animation: twinkle 6s ease-in-out infinite alternate;
  }

  .not-found-compass {
    color: var(--color-brass);
    animation: compassBob 4s ease-in-out infinite;
  }

  .not-found-needle {
    transform-origin: 48px 48px;
    animation: needleWobble 5s ease-in-out infinite;
  }

  .not-found-code {
    font-size: clamp(4.5rem, 18vw, 8rem);
    line-height: 0.95;
  }

  .not-found-digit {
    display: inline-block;
    animation: digitFloat 3.2s ease-in-out infinite;
  }

  .not-found-digit-mid {
    animation-delay: 0.35s;
  }

  .not-found-digit:last-child {
    animation-delay: 0.7s;
  }

  .not-found-card {
    animation: cardRise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .not-found-card-icon {
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .not-found-icon-svg {
    height: 1.375rem;
    width: 1.375rem;
    flex-shrink: 0;
  }

  .featured .not-found-icon-svg {
    height: 1.5rem;
    width: 1.5rem;
  }

  .not-found-card:hover .not-found-card-icon {
    transform: scale(1.04);
    border-color: rgb(194 159 93 / 0.45);
    box-shadow: 0 8px 20px rgb(194 159 93 / 0.16);
  }

  .not-found-card-arrow {
    transition: transform 0.25s ease, background-color 0.25s ease, border-color 0.25s ease;
  }

  .not-found-card:hover .not-found-card-arrow {
    transform: translateX(3px);
    background-color: rgb(194 159 93 / 0.12);
    border-color: rgb(194 159 93 / 0.35);
  }

  .not-found-card.featured:hover .not-found-card-arrow {
    transform: translateX(3px);
  }

  @keyframes duneDrift {
    from {
      transform: translateX(-2%) scale(1);
    }
    to {
      transform: translateX(2%) scale(1.03);
    }
  }

  @keyframes twinkle {
    from {
      opacity: 0.45;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes compassBob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  @keyframes needleWobble {
    0%,
    100% {
      transform: rotate(-8deg);
    }
    50% {
      transform: rotate(8deg);
    }
  }

  @keyframes digitFloat {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  @keyframes cardRise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .not-found-dune,
    .not-found-stars,
    .not-found-compass,
    .not-found-needle,
    .not-found-digit,
    .not-found-card {
      animation: none;
    }
  }
</style>

<script define:vars={{ lostMessages }}>
  const messageEl = document.getElementById('not-found-message');
  if (messageEl && lostMessages.length > 1) {
    let index = 0;

    window.setInterval(() => {
      messageEl.style.opacity = '0';
      window.setTimeout(() => {
        index = (index + 1) % lostMessages.length;
        messageEl.textContent = lostMessages[index];
        messageEl.style.opacity = '1';
      }, 280);
    }, 4200);
  }

  const section = document.querySelector('.not-found');
  const digits = document.querySelectorAll('.not-found-digit');

  section?.addEventListener('mousemove', (event) => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const rect = section.getBoundingClientRect();
    const x = (event.clientX - rect.left) / rect.width - 0.5;
    const y = (event.clientY - rect.top) / rect.height - 0.5;

    digits.forEach((digit, i) => {
      const depth = (i - 1) * 4;
      digit.style.transform = `translate(${x * depth}px, ${y * depth}px)`;
    });
  });

  section?.addEventListener('mouseleave', () => {
    digits.forEach((digit) => {
      digit.style.transform = '';
    });
  });
</script>
