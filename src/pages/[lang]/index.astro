---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';
import { getPostsByLang } from '../../lib/posts';
import { LANG_LABELS, LANGS, type Lang } from '../../lib/post-schema';
import { getSiteConfig } from '../../lib/site';

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const posts = await getPostsByLang(lang);
const site = getSiteConfig();
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://intolibya.com';

const hreflangAlternates = LANGS.map((l) => ({
  lang: l,
  href: `${siteUrl}/${l}`,
}));
---

<BaseLayout
  title={`${LANG_LABELS[lang]} Travel Blog — IntoLibya`}
  description={`Libya travel tips and guides in ${LANG_LABELS[lang]}. Plan your trip with IntoLibya.`}
  canonical={`${siteUrl}/${lang}`}
  ogImage={site.ogImage}
  pinterestImage={site.pinterestImage}
  lang={lang}
  hreflangAlternates={hreflangAlternates}
>
  <section class="px-4 py-12 md:px-8">
    <div class="mx-auto max-w-6xl">
      <p class="text-sm font-bold uppercase tracking-widest text-brass">IntoLibya Blog</p>
      <h1 class="mt-2 text-3xl font-black text-charcoal">{LANG_LABELS[lang]} Travel Tips</h1>

      <div class="mt-6 flex flex-wrap gap-2">
        {LANGS.map((l) => (
          <a
            href={`/${l}`}
            class:list={[
              'rounded-full px-3 py-1 text-xs font-bold',
              l === lang ? 'bg-mint text-charcoal' : 'bg-sand text-muted hover:bg-brass hover:text-white',
            ]}
            hreflang={l}
          >
            {LANG_LABELS[l]}
          </a>
        ))}
      </div>

      {posts.length ? (
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <a href={post.data.canonicalPath} class="card group overflow-hidden p-0 transition hover:-translate-y-1">
              <OptimizedImage
                src={post.data.featuredImage}
                alt=""
                width={640}
                height={360}
                widths={[320, 480, 640]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                class="h-44 w-full object-cover"
                loading="lazy"
                quality={70}
              />
              <div class="p-5">
                <time class="text-xs text-muted" datetime={post.data.publishedAt.toISOString()}>
                  {post.data.publishedAt.toLocaleDateString(lang)}
                </time>
                <h2 class="mt-2 font-bold text-charcoal group-hover:text-brass">{post.data.title}</h2>
                {post.data.excerpt && <p class="mt-2 line-clamp-3 text-sm text-muted">{post.data.excerpt}</p>}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="mt-10 text-muted">No posts imported for this language yet. Run <code class="rounded bg-sand px-1">npm run import:wp</code>.</p>
      )}
    </div>
  </section>
</BaseLayout>
