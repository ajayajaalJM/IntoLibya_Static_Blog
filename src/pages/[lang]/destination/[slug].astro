---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FinalCTA from '../../../components/FinalCTA.astro';
import OptimizedImage from '../../../components/OptimizedImage.astro';
import ImageGallery from '../../../components/ImageGallery.astro';
import BodyWithGalleries from '../../../components/BodyWithGalleries.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import TripResourceLinks from '../../../components/TripResourceLinks.astro';
import { render } from 'astro:content';
import { getAllDestinations, getDestinationTranslationSiblings } from '../../../lib/destinations';
import { galleriesAt, galleryImageObjects } from '../../../lib/galleries';
import { LANG_LABELS, type Lang } from '../../../lib/post-schema';
import { ogPathForFeaturedImage } from '../../../lib/og';
import { buildImageObject, readMediaCatalogDimensions } from '../../../lib/image-sitemap';
import { buildBreadcrumbListJsonLd, destinationDetailCrumbs } from '../../../lib/seo-links';
import { fileURLToPath } from 'node:url';
import path from 'node:path';

export async function getStaticPaths() {
  const destinations = await getAllDestinations();
  return destinations.map((destination) => ({
    params: {
      lang: destination.data.lang,
      slug: destination.data.slug,
    },
    props: { destination },
  }));
}

const { destination } = Astro.props;
const galleries = destination.data.galleries ?? [];
const inBodyGalleries = galleriesAt(galleries, 'in-body');
const afterHero = galleriesAt(galleries, 'after-hero');
const afterBody = galleriesAt(galleries, 'after-body');
const useSplitBody = inBodyGalleries.length > 0;

const { Content } = useSplitBody
  ? { Content: null as null }
  : await render(destination);
const allDestinations = await getAllDestinations();
const siblings = getDestinationTranslationSiblings(destination, allDestinations);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://intolibya.com';
const lang = destination.data.lang as Lang;
const ogImage = ogPathForFeaturedImage(destination.data.featuredImage);

const hreflangAlternates = [
  { lang, href: `${siteUrl}${destination.data.canonicalPath}` },
  ...siblings.map((s) => ({
    lang: s.data.lang,
    href: `${siteUrl}${s.data.canonicalPath}`,
  })),
  { lang: 'x-default', href: `${siteUrl}${destination.data.canonicalPath}` },
];

const repoRoot = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '../../..');
const mediaMeta = await readMediaCatalogDimensions(repoRoot);
const imageObjects = galleryImageObjects(galleries, siteUrl, mediaMeta);
const heroMeta = mediaMeta.get(destination.data.featuredImage);
const heroObject = buildImageObject(siteUrl, {
  src: destination.data.featuredImage,
  alt:
    destination.data.featuredImageAlt?.trim() ||
    heroMeta?.defaultAlt ||
    destination.data.title,
  name: destination.data.title,
  width: heroMeta?.width,
  height: heroMeta?.height,
  credit: heroMeta?.credit,
});
if (heroObject) imageObjects.unshift(heroObject);

const breadcrumbItems = destinationDetailCrumbs(
  lang,
  destination.data.title,
  destination.data.canonicalPath,
);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'TouristDestination',
    name: destination.data.title,
    description: destination.data.seo.description,
    url: destination.data.seo.canonical,
    primaryImageOfPage: heroObject || undefined,
    image: imageObjects.map((img) => img.contentUrl),
    inLanguage: lang,
    touristType: 'International travelers',
  },
  buildBreadcrumbListJsonLd(breadcrumbItems, siteUrl),
  ...imageObjects.map((img) => ({
    '@context': 'https://schema.org',
    ...img,
  })),
];
---

<BaseLayout
  title={destination.data.seo.title}
  description={destination.data.seo.description}
  canonical={destination.data.seo.canonical}
  ogImage={ogImage}
  ogType="article"
  articlePublishedTime={destination.data.publishedAt.toISOString()}
  articleAuthor="IntoLibya"
  articleSection={`${LANG_LABELS[lang]} Destinations`}
  lang={lang}
  hreflangAlternates={hreflangAlternates}
  jsonLd={jsonLd}
>
  <article class="px-4 py-10 md:px-8">
    <div class="mx-auto max-w-[42rem]">
      <Breadcrumbs items={breadcrumbItems} />

      <OptimizedImage
        src={destination.data.featuredImage}
        alt={destination.data.featuredImageAlt?.trim() || destination.data.title}
        width={1200}
        height={675}
        widths={[640, 960, 1200]}
        sizes="(max-width: 768px) 100vw, 672px"
        pictureClass="hero-arch mb-10 block overflow-hidden"
        class="h-64 w-full object-cover md:h-96"
        loading="eager"
        fetchpriority="high"
        quality={70}
      />

      <header class="mb-10">
        <time
          class="text-xs font-medium tracking-[0.08em] text-muted uppercase"
          datetime={destination.data.publishedAt.toISOString()}
        >
          {destination.data.publishedAt.toLocaleDateString(lang, {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <h1 class="mt-4 font-serif text-[1.85rem] font-semibold leading-snug text-balance text-charcoal md:text-[2.15rem]">
          {destination.data.title}
        </h1>
      </header>

      {
        siblings.length > 0 && (
          <div class="mb-10 flex flex-wrap gap-x-3 gap-y-2">
            {[
              { lang, path: destination.data.canonicalPath, current: true },
              ...siblings.map((s) => ({
                lang: s.data.lang,
                path: s.data.canonicalPath,
                current: false,
              })),
            ].map((t) => (
              <a
                href={t.path}
                class:list={[
                  'text-xs font-medium tracking-wide transition',
                  t.current
                    ? 'text-charcoal underline decoration-mint decoration-2 underline-offset-4'
                    : 'text-muted hover:text-brass',
                ]}
                hreflang={t.lang}
              >
                {LANG_LABELS[t.lang as Lang]}
              </a>
            ))}
          </div>
        )
      }

      {afterHero.map((gallery) => <ImageGallery gallery={gallery} />)}

      <div class="prose-blog">
        {
          useSplitBody ? (
            <BodyWithGalleries body={destination.body} galleries={galleries} />
          ) : Content ? (
            <Content />
          ) : null
        }
      </div>

      {afterBody.map((gallery) => <ImageGallery gallery={gallery} />)}
    </div>
  </article>
  <TripResourceLinks variant="compact" markEnglishHubs={lang !== 'en'} />
  <FinalCTA />
</BaseLayout>
