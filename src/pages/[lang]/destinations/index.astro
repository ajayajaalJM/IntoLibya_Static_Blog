---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import OptimizedImage from '../../../components/OptimizedImage.astro';
import { getDestinationsByLang } from '../../../lib/destinations';
import { LANG_LABELS, LANGS, type Lang } from '../../../lib/post-schema';
import { getSiteConfig } from '../../../lib/site';

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const destinations = await getDestinationsByLang(lang);
const site = getSiteConfig();
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://intolibya.com';
const pagePath = `/${lang}/destinations`;
const pageUrl = `${siteUrl}${pagePath}`;

const hreflangAlternates = [
  ...LANGS.map((l) => ({
    lang: l,
    href: `${siteUrl}/${l}/destinations`,
  })),
  { lang: 'x-default', href: `${siteUrl}/en/destinations` },
];

const itemListElement = destinations.map((destination, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  name: destination.data.title,
  url: `${siteUrl}${destination.data.canonicalPath}`,
  image: `${siteUrl}${destination.data.featuredImage}`,
}));

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${LANG_LABELS[lang]} Destinations — IntoLibya`,
    description: `Explore Libya destinations in ${LANG_LABELS[lang]}: Tripoli, Leptis Magna, Ghadames, Sahara oases, and more with IntoLibya.`,
    url: pageUrl,
    inLanguage: lang,
    isPartOf: {
      '@type': 'WebSite',
      name: 'IntoLibya',
      url: siteUrl,
    },
    about: {
      '@type': 'TouristDestination',
      name: 'Libya',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `${LANG_LABELS[lang]} Libya Destinations`,
    numberOfItems: destinations.length,
    itemListElement,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: siteUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Destinations',
        item: pageUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={`${LANG_LABELS[lang]} Destinations — IntoLibya`}
  description={`Libya destinations and places to visit in ${LANG_LABELS[lang]}: Tripoli, Leptis Magna, Ghadames, Sabratha, Sahara lakes, and more. Plan your trip with IntoLibya.`}
  canonical={pageUrl}
  ogImage={site.ogImage}
  pinterestImage={site.pinterestImage}
  lang={lang}
  hreflangAlternates={hreflangAlternates}
  jsonLd={jsonLd}
>
  <section class="px-4 py-12 md:px-8">
    <div class="mx-auto max-w-6xl">
      <p class="text-sm font-bold uppercase tracking-widest text-brass">IntoLibya Destinations</p>
      <h1 class="mt-2 text-3xl font-black text-charcoal">{LANG_LABELS[lang]} Destinations</h1>
      <p class="mt-3 max-w-2xl text-muted">
        Places across Libya — coastal cities, UNESCO heritage, desert oases, and Sahara landscapes.
      </p>

      <div class="mt-6 flex flex-wrap gap-2">
        {LANGS.map((l) => (
          <a
            href={`/${l}/destinations`}
            class:list={[
              'rounded-full px-3 py-1 text-xs font-bold',
              l === lang ? 'bg-mint text-charcoal' : 'bg-sand text-muted hover:bg-brass hover:text-white',
            ]}
            hreflang={l}
          >
            {LANG_LABELS[l]}
          </a>
        ))}
      </div>

      {destinations.length ? (
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {destinations.map((destination) => (
            <a
              href={destination.data.canonicalPath}
              class="card group overflow-hidden p-0 transition hover:-translate-y-1"
            >
              <OptimizedImage
                src={destination.data.featuredImage}
                alt={destination.data.title}
                width={640}
                height={360}
                widths={[320, 480, 640]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                class="h-44 w-full object-cover"
                loading="lazy"
                quality={70}
              />
              <div class="p-5">
                <time class="text-xs text-muted" datetime={destination.data.publishedAt.toISOString()}>
                  {destination.data.publishedAt.toLocaleDateString(lang)}
                </time>
                <h2 class="mt-2 font-bold text-charcoal group-hover:text-brass">
                  {destination.data.title}
                </h2>
                {destination.data.excerpt && (
                  <p class="mt-2 line-clamp-3 text-sm text-muted">{destination.data.excerpt}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="mt-10 text-muted">No destinations published for this language yet.</p>
      )}
    </div>
  </section>
</BaseLayout>
