---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import { getSiteConfig } from '../lib/site';
import { OG_HEIGHT, OG_WIDTH, PIN_HEIGHT, PIN_WIDTH } from '../lib/og';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  /** When set, also emit a vertical Pinterest-friendly og:image (homepage / blog indexes). */
  pinterestImage?: string;
  lang?: string;
  dir?: 'ltr' | 'rtl';
  hreflangAlternates?: Array<{ lang: string; href: string }>;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Optional LCP image preload (from getImage). */
  lcpImage?: { src: string; type?: string };
}

const {
  title,
  description = 'IntoLibya — curated Libya tours, travel tips, and TourBuilder itineraries.',
  canonical,
  ogImage,
  pinterestImage,
  lang = 'en',
  dir = lang === 'ar' ? 'rtl' : 'ltr',
  hreflangAlternates = [],
  jsonLd,
  lcpImage,
} = Astro.props;

const site = getSiteConfig();
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://intolibya.com';
const canonicalUrl = canonical || Astro.url.href;
const resolvedOgImage = ogImage || site.ogImage || site.logo;
const ogImageUrl = resolvedOgImage.startsWith('http')
  ? resolvedOgImage
  : `${siteUrl}${resolvedOgImage}`;
const pinImageUrl = pinterestImage
  ? pinterestImage.startsWith('http')
    ? pinterestImage
    : `${siteUrl}${pinterestImage}`
  : undefined;
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={site.favicon} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {hreflangAlternates.map((alt) => (
      <link rel="alternate" hreflang={alt.lang} href={alt.href} />
    ))}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(OG_WIDTH)} />
    <meta property="og:image:height" content={String(OG_HEIGHT)} />
    <meta property="og:image:alt" content={title} />
    {pinImageUrl && (
      <>
        <meta property="og:image" content={pinImageUrl} />
        <meta property="og:image:width" content={String(PIN_WIDTH)} />
        <meta property="og:image:height" content={String(PIN_HEIGHT)} />
        <meta property="og:image:alt" content={title} />
        <meta name="pinterest-rich-pin" content="true" />
      </>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://cdn.intolibya.com" />
    {lcpImage && (
      <link
        rel="preload"
        as="image"
        href={lcpImage.src}
        type={lcpImage.type}
        fetchpriority="high"
      />
    )}
    <slot name="head" />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    <GoogleAnalytics />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
