---
import { getSiteConfig } from '../lib/site';

const site = getSiteConfig();
---

<section class="px-4 py-8 md:px-8 md:py-10">
  <div class="mx-auto max-w-4xl px-1">
    <div class="card border-l-8 border-brass p-6 md:p-8">
      <blockquote class="text-base leading-relaxed text-charcoal md:text-lg">"{site.testimonial.quote}"</blockquote>
      <footer class="mt-6">
        <p class="font-bold text-charcoal">{site.testimonial.author}</p>
        <p class="text-sm text-muted">{site.testimonial.role}</p>
      </footer>
    </div>
  </div>
</section>
