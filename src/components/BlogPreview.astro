---
import { getLatestPosts } from '../lib/posts';
import OptimizedImage from './OptimizedImage.astro';

const posts = await getLatestPosts('en', 3);
---

<section class="bg-white px-4 py-8 md:px-8 md:py-10" data-ga-section="blog_preview">
  <div class="mx-auto max-w-6xl">
    <div class="mb-5 flex items-end justify-between gap-4">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-brass">Blog & Tips</p>
        <h2 class="mt-1 text-xl font-black uppercase tracking-wide text-charcoal md:text-2xl">Travel Tips and Blog</h2>
      </div>
      <a href="/en/" class="text-sm font-bold text-brass hover:underline shrink-0">Read all →</a>
    </div>
    {posts.length ? (
      <div class="grid gap-4 md:grid-cols-3">
        {posts.map((post) => (
          <a href={post.data.canonicalPath} class="card group overflow-hidden p-0 transition hover:-translate-y-1">
            {post.data.featuredImage && (
              <div class="hero-arch mx-3 mt-3 h-36 overflow-hidden bg-sand">
                <OptimizedImage
                  src={post.data.featuredImage}
                  alt=""
                  width={640}
                  height={400}
                  widths={[320, 480, 640]}
                  sizes="(max-width: 768px) 100vw, 33vw"
                  class="hero-arch-media"
                  loading="lazy"
                  quality={70}
                />
              </div>
            )}
            <div class="p-4">
              <time class="text-xs text-muted" datetime={post.data.publishedAt.toISOString()}>
                {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h3 class="mt-2 font-bold text-charcoal group-hover:text-brass">{post.data.title}</h3>
              {post.data.excerpt && <p class="mt-2 line-clamp-3 text-sm text-muted">{post.data.excerpt}</p>}
              <span class="mt-4 inline-block text-sm font-bold text-brass">Read more →</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-muted">Blog posts will appear here after WordPress import.</p>
    )}
  </div>
</section>
