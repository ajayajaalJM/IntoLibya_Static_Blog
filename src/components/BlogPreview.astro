---
import { getLatestPosts } from '../lib/posts';

const posts = await getLatestPosts('en', 3);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://intolibya.com';
---

<section class="bg-white px-4 py-16 md:px-8">
  <div class="mx-auto max-w-6xl">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <p class="text-sm font-bold uppercase tracking-widest text-brass">Blog & Tips</p>
        <h2 class="mt-2 text-2xl font-black uppercase tracking-wide text-charcoal">Travel Tips and Blog</h2>
      </div>
      <a href="/en/" class="text-sm font-bold text-brass hover:underline">Read all blog →</a>
    </div>
    {posts.length ? (
      <div class="grid gap-6 md:grid-cols-3">
        {posts.map((post) => (
          <a href={post.data.canonicalPath} class="card group overflow-hidden p-0 transition hover:-translate-y-1">
            {post.data.featuredImage && (
              <img src={post.data.featuredImage} alt="" class="h-44 w-full object-cover" loading="lazy" />
            )}
            <div class="p-5">
              <time class="text-xs text-muted" datetime={post.data.publishedAt.toISOString()}>
                {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h3 class="mt-2 font-bold text-charcoal group-hover:text-brass">{post.data.title}</h3>
              {post.data.excerpt && <p class="mt-2 line-clamp-3 text-sm text-muted">{post.data.excerpt}</p>}
              <span class="mt-4 inline-block text-sm font-bold text-brass">Read more →</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-muted">Blog posts will appear here after WordPress import.</p>
    )}
  </div>
</section>
