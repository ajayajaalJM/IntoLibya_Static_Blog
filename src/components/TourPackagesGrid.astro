---
import { tourBookingUrl, tourImageUrl } from '../lib/tourbuilder-links';
import OptimizedImage from './OptimizedImage.astro';

interface Tour {
  id: string;
  title: string;
  days: number;
  description?: string;
}

let tours: Tour[] = [];
try {
  const res = await fetch('https://cdn.intolibya.com/json/tours.json');
  if (res.ok) tours = await res.json();
} catch {
  tours = [];
}
---

<section id="tours" class="scroll-mt-20 bg-white px-4 py-8 md:px-8 md:py-10" data-ga-section="tours">
  <div class="mx-auto max-w-6xl">
    <div class="mb-5 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-brass">Tour packages</p>
        <h2 class="mt-1 text-xl font-black uppercase tracking-wide text-charcoal md:text-2xl">
          Multi-day Libya itineraries
        </h2>
        <p class="mt-1 max-w-2xl text-sm text-muted">
          Pick a package — opens in TourBuilder with the itinerary ready to customize.
        </p>
      </div>
      <a href="/tourbuilder/tour-packages" class="text-sm font-bold text-brass hover:underline shrink-0">
        All packages →
      </a>
    </div>

    {tours.length ? (
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        {tours.map((t, index) => (
          <a
            href={tourBookingUrl(t.id)}
            data-ga-item-id={t.id}
            data-ga-item-type="tour"
            data-ga-item-name={t.title}
            data-ga-item-index={String(index)}
            class="card group flex flex-col overflow-hidden border-l-8 border-brass transition hover:-translate-y-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brass"
          >
            <div class="hero-arch mx-3 mt-3 h-36 overflow-hidden bg-sand sm:mx-3 sm:mt-3 sm:h-40">
              <OptimizedImage
                src={tourImageUrl(t.id)}
                alt={t.title}
                width={640}
                height={480}
                widths={[320, 480, 640]}
                sizes="(max-width: 640px) 100vw, (max-width: 1280px) 50vw, 25vw"
                class="hero-arch-media transition group-hover:scale-105"
                loading="lazy"
                quality={70}
              />
            </div>
            <div class="flex flex-1 flex-col p-3 sm:p-4">
              <span class="text-xs font-bold uppercase tracking-wide text-brass">{t.days} days</span>
              <h3 class="mt-1 text-base font-bold text-charcoal group-hover:text-brass">{t.title}</h3>
              {t.description && (
                <p class="mt-1 line-clamp-2 flex-1 text-sm leading-relaxed text-muted">{t.description}</p>
              )}
              <span class="btn-primary mt-3 w-full justify-center py-2.5 text-xs">
                Add to booking →
              </span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-muted">Tour packages loading…</p>
    )}
  </div>
</section>
