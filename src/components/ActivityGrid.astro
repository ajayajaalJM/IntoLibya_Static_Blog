---
import { activityUrl } from '../lib/tourbuilder-links';
import OptimizedImage from './OptimizedImage.astro';

interface Activity {
  id: string;
  title: string;
  location?: string;
  duration?: string | number;
  price?: number;
  image?: string;
  display?: boolean;
}

let activities: Activity[] = [];
try {
  const res = await fetch('https://cdn.intolibya.com/json/activities.json');
  if (res.ok) {
    const data = (await res.json()) as Activity[];
    activities = data.filter((a) => a.display !== false).slice(0, 6);
  }
} catch {
  activities = [];
}

function formatDuration(duration: string | number | undefined): string {
  if (duration == null || duration === '') return '';
  const raw = String(duration).trim();
  if (/hour/i.test(raw)) return raw;
  const hours = Number(raw);
  if (!Number.isNaN(hours)) {
    return `${hours} ${hours === 1 ? 'hour' : 'hours'}`;
  }
  return raw;
}

function activityMeta(a: Activity): string {
  const parts = [a.location, formatDuration(a.duration)].filter(Boolean);
  return parts.join(' · ');
}
---

<section id="activities" class="scroll-mt-20 px-4 py-8 md:px-8 md:py-10" data-ga-section="activities">
  <div class="mx-auto max-w-6xl">
    <div class="mb-5 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-brass">Activities</p>
        <h2 class="mt-1 text-xl font-black uppercase tracking-wide text-charcoal md:text-2xl">
          Activities & Experiences
        </h2>
        <p class="mt-1 text-sm text-muted">Add experiences to your TourBuilder itinerary.</p>
      </div>
      <a href="/tourbuilder/search" class="text-sm font-bold text-brass hover:underline shrink-0">
        All activities →
      </a>
    </div>
    {activities.length ? (
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {activities.map((a) => (
          <a
            href={activityUrl(a)}
            class="card group flex flex-col overflow-hidden border-l-8 border-mint transition hover:-translate-y-1 active:scale-[0.99]"
          >
            <div class="tile-media mx-3 mt-3 h-36">
              {a.image && (
                <OptimizedImage
                  src={a.image}
                  alt={a.title}
                  width={640}
                  height={400}
                  widths={[320, 480, 640]}
                  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                  class="transition group-hover:scale-105"
                  loading="lazy"
                  quality={70}
                />
              )}
            </div>
            <div class="flex flex-1 flex-col p-3 sm:p-4">
              <h3 class="font-bold leading-snug text-charcoal group-hover:text-brass">{a.title}</h3>
              {activityMeta(a) && <p class="mt-1 text-sm text-muted">{activityMeta(a)}</p>}
              {a.price != null && (
                <p class="mt-1 text-sm font-bold text-brass">From {a.price} USD</p>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-muted">Activities loading from TourBuilder CDN…</p>
    )}
  </div>
</section>
