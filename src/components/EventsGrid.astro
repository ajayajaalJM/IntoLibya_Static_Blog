---
import { eventBookingUrl, eventSlug } from '../lib/tourbuilder-links';
import OptimizedImage from './OptimizedImage.astro';

interface EventItem {
  id: string;
  title: string;
  days: number;
  price?: number;
  description?: string;
  overview?: string;
  image?: string;
  images?: string[];
  scheduleType?: string;
  isLibyanOnly?: boolean;
}

let events: EventItem[] = [];
try {
  const res = await fetch('https://cdn.intolibya.com/json/events.json');
  if (res.ok) events = await res.json();
} catch {
  events = [];
}

function eventImage(e: EventItem): string {
  if (e.image) return e.image;
  if (e.images?.[0]) return e.images[0];
  return '/assets/heroes/hero_sahara.jpg';
}

function eventDescription(e: EventItem): string {
  return (e.overview || e.description || '').slice(0, 220);
}
---

<section id="events" class="scroll-mt-20 px-4 py-8 md:px-8 md:py-10" data-ga-section="events">
  <div class="mx-auto max-w-6xl">
    <div class="mb-5 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-brass">Festivals & events</p>
        <h2 class="mt-1 text-xl font-black uppercase tracking-wide text-charcoal md:text-2xl">
          Events we run
        </h2>
        <p class="mt-1 max-w-2xl text-sm text-muted">
          Join a scheduled group trip — opens in TourBuilder with the event on your calendar.
        </p>
      </div>
      <a href="/tourbuilder/festivals-and-events" class="text-sm font-bold text-brass hover:underline shrink-0">
        All events →
      </a>
    </div>

    {events.length ? (
      <div class="grid gap-6 md:grid-cols-2">
        {events.map((e) => (
          <article class="card group flex flex-col overflow-hidden border-l-8 border-mint">
            <div class="tile-media mx-4 mt-4 h-52 sm:h-56">
              <OptimizedImage
                src={eventImage(e)}
                alt=""
                width={800}
                height={500}
                widths={[400, 640, 800]}
                sizes="(max-width: 768px) 100vw, 50vw"
                class="transition group-hover:scale-105"
                loading="lazy"
                quality={70}
              />
            </div>

            <div class="flex flex-1 flex-col p-5 sm:p-6">
              <div class="flex flex-wrap items-center gap-2">
                <span class="text-xs font-bold uppercase tracking-wide text-brass">
                  {e.days} days · {e.scheduleType === 'fixed' ? 'Fixed dates' : 'Scheduled'}
                </span>
                {e.isLibyanOnly && (
                  <span class="rounded-full bg-charcoal px-3 py-1 text-xs font-bold text-white">
                    Libyans Only
                  </span>
                )}
              </div>

              <h3 class="mt-3 text-xl font-bold leading-snug text-charcoal sm:text-2xl">{e.title}</h3>

              {eventDescription(e) && (
                <p class="mt-3 flex-1 text-base leading-relaxed text-muted">
                  {eventDescription(e)}
                </p>
              )}

              {e.price != null && (
                <p class="mt-4 text-base font-bold text-charcoal">From {e.price} USD</p>
              )}

              <div class="mt-5 flex flex-col gap-3 sm:flex-row">
                <a
                  href={eventBookingUrl(e.id)}
                  data-ga-event="cta_click"
                  data-ga-label="Book Event"
                  class="btn-primary flex-1 justify-center py-3 text-sm"
                >
                  Book Now →
                </a>
                <a
                  href={`/tourbuilder/festivals-and-events/${eventSlug(e)}`}
                  class="btn-secondary flex-1 justify-center py-3 text-sm"
                >
                  Details
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <p class="text-muted">Events loading from TourBuilder CDN…</p>
    )}
  </div>
</section>
