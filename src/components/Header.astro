---
import { getSiteConfig } from '../lib/site';
import OptimizedImage from './OptimizedImage.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const site = getSiteConfig();

const navLinks = [
  { href: '/tourbuilder/booking/', label: 'Build Trip' },
  { href: '/#tours', label: 'Tours' },
  { href: '/#events', label: 'Events' },
  { href: '/#activities', label: 'Activities' },
  { href: '/en/', label: 'Blog' },
];

const whatsappUrl = `https://wa.me/${site.contact.whatsapp}?text=${encodeURIComponent(site.contact.whatsappMessage)}`;
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-whitewash/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 md:gap-4 md:px-8">
    <a href="/" class="flex min-w-0 shrink items-center gap-2">
      <OptimizedImage
        src={site.logo}
        alt="IntoLibya"
        width={96}
        height={96}
        widths={[48, 96]}
        sizes="48px"
        class="h-11 w-auto object-contain md:h-12"
        loading="eager"
        decoding="async"
        quality={80}
      />
    </a>

    <nav class="hidden items-center gap-5 text-sm font-medium text-muted lg:flex" aria-label="Main">
      {navLinks.map((link) => (
        <a href={link.href} class="whitespace-nowrap hover:text-brass">{link.label}</a>
      ))}
    </nav>

    <div class="flex shrink-0 items-center gap-2">
      <a
        href={site.primaryCtaUrl}
        data-ga-event="cta_click"
        data-ga-label="Build Your Trip"
        class="btn-primary px-3 py-2 text-[11px] sm:px-4 sm:py-2.5 sm:text-xs md:text-sm"
      >
        {site.primaryCtaText}
      </a>
      <button
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border-2 border-brass/30 bg-white text-brass shadow-sm transition hover:border-brass hover:bg-brass/5 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav"
        id="menu-toggle"
      >
        <span class="sr-only">Open menu</span>
        <svg class="h-5 w-5 menu-icon-open" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
        <svg class="hidden h-5 w-5 menu-icon-close" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
  </div>
</header>

<div id="mobile-nav-backdrop" class="mobile-drawer-backdrop" hidden aria-hidden="true"></div>

<aside
  id="mobile-nav"
  class="mobile-drawer"
  hidden
  aria-hidden="true"
  aria-label="Mobile navigation"
>
  <div class="mobile-drawer-inner">
    <div class="mobile-drawer-header">
      <a href="/" class="mobile-drawer-brand">
        <OptimizedImage
          src={site.logoDark}
          alt="IntoLibya"
          width={80}
          height={80}
          widths={[40, 80]}
          sizes="40px"
          class="h-10 w-auto"
          loading="lazy"
          quality={80}
        />
        <span>IntoLibya</span>
      </a>
      <button type="button" class="mobile-drawer-close" id="menu-close" aria-label="Close menu">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>

    <nav class="mobile-drawer-nav" aria-label="Mobile">
      {navLinks.map((link) => (
        <a href={link.href} class="mobile-drawer-link">{link.label}</a>
      ))}
      <a
        href={site.primaryCtaUrl}
        data-ga-event="cta_click"
        data-ga-label="Build Your Trip"
        class="mobile-drawer-cta"
      >
        {site.primaryCtaText}
      </a>
    </nav>

    <section class="mobile-drawer-contact" aria-label="Contact">
      <p class="mobile-drawer-label">Contact</p>
      <ul class="mobile-drawer-contact-list">
        <li>
          <a href={`tel:${site.contact.phoneTel}`} class="mobile-drawer-contact-link">
            <span class="mobile-drawer-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" d="M5 4h4l2 5-2.5 1.5a11 11 0 005 5L15 13l5 2v4a2 2 0 01-2 2A16 16 0 013 6a2 2 0 012-2z"/></svg>
            </span>
            <span>
              <span class="mobile-drawer-contact-title">Phone</span>
              <span class="mobile-drawer-contact-value">{site.contact.phone}</span>
            </span>
          </a>
        </li>
        <li>
          <a href={whatsappUrl} class="mobile-drawer-contact-link" rel="noopener noreferrer" target="_blank">
            <span class="mobile-drawer-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 00-8.7 14.9L2 22l5.3-1.3A10 10 0 1012 2zm0 18a8 8 0 01-4.1-1.1l-.3-.2-3.1.8.8-3-0.2-.3A8 8 0 1112 20zm4.5-5.9c-.2-.1-1.3-.6-1.5-.7s-.3-.1-.5.1-.6.7-.7.8-.3.2-.5.1a6 6 0 01-1.8-1.1 6.7 6.7 0 01-1.2-1.5c-.1-.2 0-.3.1-.4.1-.1.2-.3.3-.4.1-.1.1-.2.2-.3.1-.1 0-.2 0-.3 0-.1-.5-1.3-.7-1.8-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.5.1-.7.3s-1 1-1 2.4 1 2.8 1.2 3a7.2 7.2 0 005.4 5.1c.8.3 1.4.5 1.9.6.8.3 1.5.2 2 .1.6-.1 1.3-.6 1.5-1.1s.2-1 .1-1.1-.2-.2-.4-.3z"/></svg>
            </span>
            <span>
              <span class="mobile-drawer-contact-title">WhatsApp</span>
              <span class="mobile-drawer-contact-value">Message us</span>
            </span>
          </a>
        </li>
        <li>
          <a href={`mailto:${site.contact.email}`} class="mobile-drawer-contact-link">
            <span class="mobile-drawer-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16v12H4z"/><path stroke-linecap="round" d="M4 7l8 6 8-6"/></svg>
            </span>
            <span>
              <span class="mobile-drawer-contact-title">Email</span>
              <span class="mobile-drawer-contact-value">{site.contact.email}</span>
            </span>
          </a>
        </li>
        <li>
          <a href={site.social.instagram} class="mobile-drawer-contact-link" rel="noopener noreferrer" target="_blank">
            <span class="mobile-drawer-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="4" width="16" height="16" rx="4"/><circle cx="12" cy="12" r="3.5"/><circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none"/></svg>
            </span>
            <span>
              <span class="mobile-drawer-contact-title">Instagram</span>
              <span class="mobile-drawer-contact-value">{site.contact.instagramHandle}</span>
            </span>
          </a>
        </li>
      </ul>
    </section>

    <blockquote class="mobile-drawer-quote">
      <p>“{site.quote.text}”</p>
      <footer>— {site.quote.author}</footer>
    </blockquote>
  </div>
</aside>

<style>
  #menu-toggle[aria-expanded='true'] {
    border-color: var(--color-brass);
    background-color: rgb(194 159 93 / 0.12);
  }

  .mobile-drawer-backdrop {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: rgb(45 42 38 / 0.45);
    backdrop-filter: blur(3px);
    opacity: 0;
    transition: opacity 0.32s ease;
  }

  .mobile-drawer-backdrop.is-open {
    opacity: 1;
  }

  .mobile-drawer {
    position: fixed;
    inset: 0 0 0 auto;
    z-index: 70;
    width: min(88vw, 22rem);
    max-width: 100%;
    background: linear-gradient(180deg, #2d2a26 0%, #24211d 100%);
    color: var(--color-whitewash);
    box-shadow: -20px 0 60px rgb(0 0 0 / 0.28);
    transform: translateX(100%);
    transition: transform 0.36s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mobile-drawer.is-open {
    transform: translateX(0);
  }

  .mobile-drawer-inner {
    display: flex;
    height: 100%;
    flex-direction: column;
    overflow-y: auto;
    padding: 1.25rem 1.25rem 1.5rem;
  }

  .mobile-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.08);
  }

  .mobile-drawer-brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: inherit;
    text-decoration: none;
  }

  .mobile-drawer-close {
    display: inline-flex;
    height: 2.5rem;
    width: 2.5rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgb(255 255 255 / 0.12);
    background: rgb(255 255 255 / 0.04);
    color: inherit;
    cursor: pointer;
  }

  .mobile-drawer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .mobile-drawer-link {
    padding: 0.85rem 0.25rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.06);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: rgb(255 255 255 / 0.92);
    text-decoration: none;
    transition: color 0.2s ease, padding-left 0.2s ease;
  }

  .mobile-drawer-link:hover {
    color: var(--color-brass);
    padding-left: 0.35rem;
  }

  .mobile-drawer-cta {
    margin-top: 0.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--color-brass);
    padding: 0.9rem 1rem;
    font-size: 0.95rem;
    font-weight: 800;
    color: white;
    text-decoration: none;
    box-shadow: 0 10px 28px rgb(194 159 93 / 0.28);
  }

  .mobile-drawer-contact {
    margin-top: 1.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgb(255 255 255 / 0.08);
  }

  .mobile-drawer-label {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brass);
  }

  .mobile-drawer-contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
  }

  .mobile-drawer-contact-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0.7rem;
    border-radius: 0.9rem;
    background: rgb(255 255 255 / 0.04);
    border: 1px solid rgb(255 255 255 / 0.06);
    color: inherit;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .mobile-drawer-contact-link:hover {
    background: rgb(255 255 255 / 0.07);
    border-color: rgb(194 159 93 / 0.35);
  }

  .mobile-drawer-icon {
    display: inline-flex;
    height: 2rem;
    width: 2rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgb(194 159 93 / 0.14);
    color: var(--color-brass);
  }

  .mobile-drawer-icon svg {
    height: 1rem;
    width: 1rem;
  }

  .mobile-drawer-contact-title {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.55);
  }

  .mobile-drawer-contact-value {
    display: block;
    margin-top: 0.1rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: rgb(255 255 255 / 0.92);
  }

  .mobile-drawer-quote {
    margin: auto 0 0;
    padding-top: 1.25rem;
    border-top: 1px solid rgb(255 255 255 / 0.08);
    font-style: italic;
  }

  .mobile-drawer-quote p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: rgb(255 255 255 / 0.82);
  }

  .mobile-drawer-quote footer {
    margin-top: 0.65rem;
    font-size: 0.78rem;
    font-style: normal;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-brass);
  }

  @media (min-width: 1024px) {
    .mobile-drawer-backdrop,
    .mobile-drawer {
      display: none !important;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const closeBtn = document.getElementById('menu-close');
  const panel = document.getElementById('mobile-nav');
  const backdrop = document.getElementById('mobile-nav-backdrop');
  const openIcon = toggle?.querySelector('.menu-icon-open');
  const closeIcon = toggle?.querySelector('.menu-icon-close');

  function setOpen(open: boolean) {
    if (!panel || !backdrop || !toggle) return;

    toggle.setAttribute('aria-expanded', String(open));
    panel.toggleAttribute('hidden', !open);
    backdrop.toggleAttribute('hidden', !open);
    panel.setAttribute('aria-hidden', String(!open));
    backdrop.setAttribute('aria-hidden', String(!open));
    panel.classList.toggle('is-open', open);
    backdrop.classList.toggle('is-open', open);
    document.body.classList.toggle('overflow-hidden', open);
    openIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
  }

  toggle?.addEventListener('click', () => {
    const open = panel?.hasAttribute('hidden');
    setOpen(Boolean(open));
  });

  closeBtn?.addEventListener('click', () => setOpen(false));
  backdrop?.addEventListener('click', () => setOpen(false));

  panel?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && panel && !panel.hasAttribute('hidden')) {
      setOpen(false);
    }
  });
</script>
