---
/**
 * Loads GA4 when PUBLIC_GA_MEASUREMENT_ID is set (shared stream with TourBuilder).
 * See docs/ANALYTICS.md — event taxonomy + TourBuilder sessionStorage handoff.
 */
import type { ContentMeta } from '../lib/analytics';

interface Props extends ContentMeta {}

const {
  content_type: contentType = '',
  content_id: contentId = '',
  content_language: contentLanguage = '',
} = Astro.props as Props;

const measurementId = (import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? '').trim();
const pageMeta = {
  site_area: 'blog',
  content_type: contentType || undefined,
  content_id: contentId || undefined,
  content_language: contentLanguage || undefined,
};
const bootScript = measurementId
  ? `
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
window.gtag = gtag;
gtag('js', new Date());
gtag('config', ${JSON.stringify(measurementId)}, {
  anonymize_ip: true,
  send_page_view: true,
  site_area: 'blog'
});
gtag('set', 'user_properties', { site_area: 'blog' });
window.__IL_PAGE_META__ = ${JSON.stringify(pageMeta)};
`.trim()
  : '';
---

{
  measurementId && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`}></script>
      <script is:inline set:html={bootScript} />
      <script>
        import {
          buildHandoffContext,
          classifyLink,
          HANDOFF_STORAGE_KEY,
          isTourBuilderHref,
          SITE_AREA_BLOG,
        } from '../lib/analytics';

        type PageMeta = {
          site_area?: string;
          content_type?: string;
          content_id?: string;
          content_language?: string;
        };

        function textOf(el: Element) {
          return (el.textContent || '').replace(/\s+/g, ' ').trim().slice(0, 120);
        }

        function sectionOf(el: Element) {
          const tagged = el.closest('[data-ga-section]');
          if (tagged) return tagged.getAttribute('data-ga-section') || '';
          if (el.closest('header')) return 'header';
          if (el.closest('footer')) return 'footer';
          if (el.closest('.hero-full, [data-hero]')) return 'hero';
          if (el.closest('aside#mobile-nav, .mobile-drawer')) return 'mobile_nav';
          if (el.closest('article')) return 'article';
          if (el.closest('main')) return 'main';
          return 'page';
        }

        function pageMeta(): PageMeta {
          return (window as any).__IL_PAGE_META__ || { site_area: SITE_AREA_BLOG };
        }

        function track(payload: Record<string, unknown> | null | undefined) {
          if (!payload || !payload.event || typeof window.gtag !== 'function') return;
          const event = String(payload.event);
          const params: Record<string, unknown> = {};
          for (const key of Object.keys(payload)) {
            if (key !== 'event' && payload[key] !== undefined) params[key] = payload[key];
          }
          const meta = pageMeta();
          params.site_area = SITE_AREA_BLOG;
          params.page_location = window.location.href;
          params.page_path = window.location.pathname;
          if (meta.content_type) params.content_type = params.content_type || meta.content_type;
          if (meta.content_id) params.content_id = params.content_id || meta.content_id;
          if (meta.content_language) {
            params.content_language = params.content_language || meta.content_language;
          }

          // GA4 items[] for select_item
          if (event === 'select_item' && params.item_id) {
            params.items = [
              {
                item_id: params.item_id,
                item_name: params.item_name || params.link_text,
                item_category: params.item_category,
                item_list_name: params.item_list_name || params.section,
                index: params.index,
              },
            ];
          }

          window.gtag('event', event, params);
        }

        function storeHandoff(anchor: HTMLAnchorElement, payload: Record<string, unknown>) {
          if (!isTourBuilderHref(anchor.href)) return;
          try {
            const meta = pageMeta();
            const raw = buildHandoffContext({
              entry_page: window.location.pathname,
              entry_content_id: String(meta.content_id || ''),
              entry_section: String(payload.section || sectionOf(anchor) || ''),
              entry_item_id: String(payload.item_id || ''),
            });
            sessionStorage.setItem(HANDOFF_STORAGE_KEY, raw);
          } catch {
            /* ignore */
          }
        }

        document.addEventListener(
          'click',
          (e) => {
            const target = e.target;
            if (!(target instanceof Element)) return;

            const anchor = target.closest('a[href]');
            if (anchor instanceof HTMLAnchorElement) {
              const payload = classifyLink({
                href: anchor.getAttribute('href') || anchor.href,
                text: textOf(anchor),
                section: sectionOf(anchor),
                explicitEvent: anchor.getAttribute('data-ga-event'),
                explicitLabel: anchor.getAttribute('data-ga-label'),
                explicitCta: anchor.getAttribute('data-ga-cta'),
                itemId: anchor.getAttribute('data-ga-item-id'),
                itemType: anchor.getAttribute('data-ga-item-type'),
                itemName: anchor.getAttribute('data-ga-item-name'),
                itemIndex: anchor.getAttribute('data-ga-item-index'),
                siteHost: window.location.hostname,
                base: window.location.href,
              });
              track(payload);
              storeHandoff(anchor, payload);
              return;
            }

            const btn = target.closest('[data-ga-event]');
            if (btn instanceof HTMLElement && !(btn instanceof HTMLAnchorElement)) {
              track({
                event: btn.getAttribute('data-ga-event') || 'ui_click',
                link_text: btn.getAttribute('data-ga-label') || textOf(btn),
                section: sectionOf(btn),
              });
            }
          },
          true,
        );
      </script>
    </>
  )
}
