---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { localizeMediaUrl, resolveLocalImage } from '../lib/local-images';

interface Props {
  src: string | ImageMetadata;
  alt?: string;
  width: number;
  height?: number;
  widths?: number[];
  sizes: string;
  class?: string;
  pictureClass?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  decoding?: 'async' | 'auto' | 'sync';
  quality?: number;
}

const {
  src: rawSrc,
  alt = '',
  width,
  height,
  widths,
  sizes,
  class: className = '',
  pictureClass = '',
  loading = 'lazy',
  fetchpriority,
  decoding = 'async',
  quality = 75,
} = Astro.props;

const srcString = typeof rawSrc === 'string' ? localizeMediaUrl(rawSrc) : '';
const resolved: ImageMetadata | string =
  typeof rawSrc === 'string' ? (resolveLocalImage(srcString) ?? srcString) : rawSrc;

const uniqueWidths = [
  ...new Set(
    (widths ?? [Math.round(width * 0.5), Math.round(width * 0.75), width])
      .map((w) => Math.max(80, Math.round(w)))
      .sort((a, b) => a - b),
  ),
];

const fallbackHeight = height ?? Math.round(width * (2 / 3));
---

<Picture
  src={resolved}
  alt={alt}
  width={width}
  height={fallbackHeight}
  widths={uniqueWidths}
  sizes={sizes}
  formats={['avif', 'webp']}
  quality={quality}
  class={className}
  pictureAttributes={{ class: pictureClass }}
  loading={loading}
  fetchpriority={fetchpriority}
  decoding={decoding}
/>
