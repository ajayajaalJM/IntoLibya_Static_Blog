---
import { getSiteConfig } from '../lib/site';

interface Props {
  class?: string;
  variant?: 'inline' | 'footer';
}

const { class: className = '', variant = 'inline' } = Astro.props;
const site = getSiteConfig();
---

<div
  class:list={[
    variant === 'inline' && 'rounded-3xl border border-border/70 bg-white p-5 shadow-[0_12px_32px_rgba(45,42,38,0.04)] sm:p-6',
    variant === 'footer' &&
      'rounded-3xl border border-white/15 bg-charcoal p-6 shadow-[0_20px_50px_rgba(45,42,38,0.18)] sm:p-8',
    className,
  ]}
  data-ga-section={variant === 'footer' ? 'final_cta' : 'conversion_nudge'}
>
  <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
    <div class:list={[variant === 'footer' ? 'max-w-xl text-white' : 'max-w-2xl']}>
      <p
        class:list={[
          'text-xs font-bold uppercase tracking-[0.18em]',
          variant === 'footer' ? 'text-brass' : 'text-brass',
        ]}
      >
        TourBuilder
      </p>
      <h2
        class:list={[
          'mt-2 font-black leading-tight',
          variant === 'footer' ? 'text-2xl text-white md:text-3xl' : 'text-xl text-charcoal md:text-2xl',
        ]}
      >
        {variant === 'footer' ? 'Ready to explore Libya?' : 'Build your trip, one day at a time'}
      </h2>
      <p
        class:list={[
          'mt-2 text-sm leading-relaxed md:text-base',
          variant === 'footer' ? 'text-white/80' : 'text-muted',
        ]}
      >
        {variant === 'footer'
          ? 'Choose tours and activities, shape your itinerary, and send it to the IntoLibya team for a tailored quote.'
          : 'Add tours, events, and experiences to your calendar — then submit your plan when you are ready.'}
      </p>
    </div>

    <div class="flex shrink-0 flex-col gap-3 sm:flex-row lg:flex-col xl:flex-row">
      <a
        href={site.primaryCtaUrl}
        data-ga-event="cta_click"
        data-ga-label="Build Your Trip"
        class:list={[
          'inline-flex min-h-12 items-center justify-center rounded-full px-6 py-3 text-sm font-extrabold transition active:scale-[0.98]',
          variant === 'footer'
            ? 'bg-brass text-white hover:brightness-110'
            : 'bg-brass text-white shadow-[0_8px_24px_rgba(194,159,93,0.28)] hover:brightness-110',
        ]}
      >
        {site.primaryCtaText} →
      </a>
      <a
        href={site.secondaryCtaUrl}
        data-ga-event="cta_click"
        data-ga-label="Browse Activities"
        class:list={[
          'inline-flex min-h-12 items-center justify-center rounded-full border-2 px-6 py-3 text-sm font-bold transition active:scale-[0.98]',
          variant === 'footer'
            ? 'border-white/30 bg-white/5 text-white hover:bg-white/10'
            : 'border-border bg-whitewash text-charcoal hover:bg-sand',
        ]}
      >
        {site.secondaryCtaText}
      </a>
    </div>
  </div>
</div>
