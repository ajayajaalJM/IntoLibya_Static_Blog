---
import { getSiteConfig } from '../lib/site';
import OptimizedImage from './OptimizedImage.astro';

const site = getSiteConfig();
const year = new Date().getFullYear();

const nav = [
  { href: '/tourbuilder', label: 'TourBuilder' },
  { href: '/en', label: 'Travel Blog' },
  { href: '/tourbuilder/search', label: 'Activities' },
];

const socials = [
  {
    href: site.social.instagram,
    label: 'Instagram',
    icon: 'instagram',
  },
  {
    href: site.social.facebook,
    label: 'Facebook',
    icon: 'facebook',
  },
  {
    href: site.social.youtube,
    label: 'YouTube',
    icon: 'youtube',
  },
] as const;
---

<footer class="mt-16 border-t border-white/10 bg-charcoal text-whitewash">
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-4 py-8 sm:px-8">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
      <div class="flex items-center gap-3">
        <OptimizedImage
          src={site.logoDark}
          alt="IntoLibya"
          width={72}
          height={72}
          widths={[36, 72]}
          sizes="36px"
          class="h-9 w-auto object-contain"
          loading="lazy"
          quality={80}
        />
        <div>
          <p class="text-sm font-semibold tracking-wide">IntoLibya</p>
          <p class="text-xs text-white/55">Tours, guides & custom itineraries</p>
        </div>
      </div>

      <nav aria-label="Footer">
        <ul class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-white/75">
          {
            nav.map((item) => (
              <li>
                <a href={item.href} class="transition hover:text-brass">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <ul class="flex items-center gap-2" aria-label="Social media">
        {
          socials.map((item) => (
            <li>
              <a
                href={item.href}
                class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/15 text-white/80 transition hover:border-brass/50 hover:bg-brass/10 hover:text-brass"
                rel="noopener noreferrer"
                target="_blank"
                aria-label={item.label}
              >
                {item.icon === 'instagram' && (
                  <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <rect x="3.5" y="3.5" width="17" height="17" rx="4.5" />
                    <circle cx="12" cy="12" r="3.8" />
                    <circle cx="17.3" cy="6.7" r="1" fill="currentColor" stroke="none" />
                  </svg>
                )}
                {item.icon === 'facebook' && (
                  <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
                    <path d="M14 8h2.5V5.1C16.1 5 15 5 13.8 5 11.5 5 10 6.4 10 9v2H7.5v3.2H10V21h3.2v-6.8h2.6l.4-3.2H13.2V9.3c0-.9.3-1.3.8-1.3z" />
                  </svg>
                )}
                {item.icon === 'youtube' && (
                  <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
                    <path d="M21.6 7.2a2.7 2.7 0 00-1.9-1.9C18 5 12 5 12 5s-6 0-7.7.3a2.7 2.7 0 00-1.9 1.9C2 8.9 2 12 2 12s0 3.1.4 4.8a2.7 2.7 0 001.9 1.9C6 19 12 19 12 19s6 0 7.7-.3a2.7 2.7 0 001.9-1.9c.4-1.7.4-4.8.4-4.8s0-3.1-.4-4.8zM10 15.2V8.8L15.5 12 10 15.2z" />
                  </svg>
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="flex flex-col items-start justify-between gap-2 border-t border-white/10 pt-4 text-xs text-white/45 sm:flex-row sm:items-center">
      <p>© {year} IntoLibya. All rights reserved.</p>
      <a href={`mailto:${site.contact.email}`} class="transition hover:text-brass">
        {site.contact.email}
      </a>
    </div>
  </div>
</footer>
