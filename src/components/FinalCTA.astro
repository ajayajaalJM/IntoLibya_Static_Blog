---
import ConversionNudge from './ConversionNudge.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<section class={`px-4 py-8 md:px-8 md:py-12 ${className}`}>
  <div class="mx-auto max-w-6xl">
    <ConversionNudge variant="footer" />
  </div>
</section>
