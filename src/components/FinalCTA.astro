---
import TourBuilderBanner from './TourBuilderBanner.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<section class={`bg-brass px-4 py-12 text-white md:px-8 ${className}`}>
  <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-6 md:flex-row md:items-center">
    <div>
      <h2 class="text-2xl font-black md:text-3xl">Ready to explore Libya?</h2>
      <p class="mt-2 max-w-xl text-white/90">Use TourBuilder to pick activities, build your itinerary, and submit it to the IntoLibya team.</p>
    </div>
    <TourBuilderBanner variant="light" />
  </div>
</section>
